{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Web Paste",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "systemTray": {
      "iconPath": "icons/tray.png"
    },
    "bundle": {
      "active": true,
      "identifier": "com.dangolabs.webpaste",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "title": "Web Paste",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": false,
        "maximizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
